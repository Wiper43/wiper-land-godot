# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation

# Import cache (regenerated by editor)
*.import

# Exported builds
/builds/
/export/

# Godot editor temp files
*.tmp

# Python / Blender helper scripts
__pycache__/
*.py[cod]

# OS files
.DS_Store
Thumbs.db
desktop.ini

# VSCode
.vscode/
